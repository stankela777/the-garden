# Database
POSTGRES_DB=the_garden
POSTGRES_USER=garden_user
POSTGRES_PASSWORD=garden_secret
POSTGRES_PORT=5432
DATABASE_URL=postgresql://garden_user:garden_secret@postgres:5432/the_garden

# pgAdmin
PGADMIN_DEFAULT_EMAIL=admin@garden.local
PGADMIN_DEFAULT_PASSWORD=admin123
PGADMIN_PORT=5050

# Backend
BACKEND_PORT=3000
JWT_SECRET=super_secret_jwt_key_change_in_production
NODE_ENV=development

# Frontend
FRONTEND_PORT=5173
VITE_API_URL=http://localhost:3000

# MailHog
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET_PLANTS=plant-images
MINIO_BUCKET_AVATARS=user-avatars
